// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id Int @id @default(autoincrement())

  firstName String
  lastName  String
  address   String

  email  String @unique
  mobile String @unique

  password String

  idUpload String?

  role   Role       @default(RESIDENT)
  status UserStatus @default(ACTIVE)

  lastLogin      DateTime?
  failedAttempts Int       @default(0)
  isLocked       Boolean   @default(false)

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  announcements Announcement[]

  certificateRequests CertificateRequest[] @relation("ResidentRequests")
  processedRequests   CertificateRequest[] @relation("ProcessedRequests")
}

enum Role {
  ADMIN
  STAFF
  RESIDENT
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DEACTIVATED
}

model Announcement {
  id String @id @default(cuid())

  title   String
  content String

  category AnnouncementCategory
  priority AnnouncementPriority

  status AnnouncementStatus @default(DRAFT)

  authorId Int
  author   User @relation(fields: [authorId], references: [id])

  expiresAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum AnnouncementCategory {
  General
  Meeting
  Emergency
  Event
  Curfew
}

enum AnnouncementPriority {
  Normal
  Important
  Urgent
}

enum AnnouncementStatus {
  DRAFT
  PUBLISHED
}

enum CertificateType {
  BARANGAY_CLEARANCE
  BARANGAY_INDIGENCY
  BARANGAY_RESIDENCY
}

enum CertificateStatus {
  PENDING
  APPROVED
  READY_FOR_PICKUP
}

model CertificateRequest {
  id String @id @default(cuid())

  residentId Int
  resident   User @relation("ResidentRequests", fields: [residentId], references: [id])

  certificateType CertificateType
  purpose         String
  status          CertificateStatus @default(PENDING)

  dateRequested DateTime  @default(now())
  dateApproved  DateTime?

  processedById Int?
  processedBy   User? @relation("ProcessedRequests", fields: [processedById], references: [id])

  remarks       String?
  contactNumber String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
